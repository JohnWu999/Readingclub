generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(uuid())
  phone         String           @unique
  password      String
  nickname      String?
  avatar        String?
  role          Role             @default("MEMBER")
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  audioProgress AudioProgress[]
  checkIns      CheckIn[]
  comments      Comment[]
  journals      EmotionJournal[]
  familyMembers FamilyMember[]
}

model Book {
  id           String     @id @default(uuid())
  title        String
  subtitle     String?
  author       String
  coverImage   String?
  description  String?
  readingGuide String?
  cycleStart   DateTime?
  cycleEnd     DateTime?
  isActive     Boolean    @default(false)
  isPublished  Boolean    @default(false)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
  chapters     Chapter[]
  materials    Material[]
}

model Chapter {
  id         String      @id @default(uuid())
  bookId     String
  title      String
  order      Int
  summary    String?
  createdAt  DateTime    @default(now())
  content    String?
  outline    String?
  audioFiles AudioFile[]
  book       Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  comments   Comment[]
  materials  Material[]
}

model AudioFile {
  id        String          @id @default(uuid())
  chapterId String?
  healingId String?
  title     String
  url       String
  duration  Int
  type      AudioType       @default("HUMAN")
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  healing   HealingContent? @relation(fields: [healingId], references: [id], onDelete: Cascade)
  chapter   Chapter?        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress  AudioProgress[]
}

model AudioProgress {
  id          String    @id @default(uuid())
  userId      String
  audioId     String
  position    Int       @default(0)
  isCompleted Boolean   @default(false)
  updatedAt   DateTime  @updatedAt
  audio       AudioFile @relation(fields: [audioId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, audioId])
}

model Comment {
  id        String    @id @default(uuid())
  userId    String
  chapterId String?
  content   String
  images    String    @default("")
  parentId  String?
  isPinned  Boolean   @default(false)
  isEssence Boolean   @default(false)
  createdAt DateTime  @default(now())
  parent    Comment?  @relation("Reply", fields: [parentId], references: [id])
  replies   Comment[] @relation("Reply")
  chapter   Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id        String      @id @default(uuid())
  userId    String
  type      CheckInType @default("READING")
  chapterId String?
  content   String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, createdAt])
}

model EmotionJournal {
  id         String   @id @default(uuid())
  userId     String
  emotion    String
  trigger    String?
  action     String?
  reflection String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HealingContent {
  id          String          @id @default(uuid())
  category    HealingCategory
  type        String
  title       String
  description String?
  coverImage  String?
  order       Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  audioFiles  AudioFile[]
}

model FamilyMember {
  id        String   @id @default(uuid())
  userId    String
  name      String
  relation  String
  avatar    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Material {
  id        String   @id @default(uuid())
  bookId    String?
  chapterId String?
  title     String
  url       String
  type      String   @default("pdf")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  bookId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([userId])
  @@index([bookId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String
  toolRefs       String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model UserProblem {
  id        String   @id @default(uuid())
  userId    String   @unique
  problems  String
  childInfo String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ChapterInsight {
  id         String   @id @default(uuid())
  chapterId  String
  problemTag String
  hint       String
  quote      String
  pageRef    String
  isRevealed Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([chapterId])
  @@index([problemTag])
}

model KnowledgeNode {
  id          String          @id @default(uuid())
  name        String          @unique
  category    String
  description String?
  tools       String?
  createdAt   DateTime        @default(now())
  links       KnowledgeLink[]
}

model KnowledgeLink {
  id         String        @id @default(uuid())
  nodeId     String
  bookId     String
  chapterId  String?
  contentRef String
  context    String
  pageRef    String
  createdAt  DateTime      @default(now())
  node       KnowledgeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([bookId])
  @@index([chapterId])
}

enum Role {
  MEMBER
  ADMIN
}

enum AudioType {
  HUMAN
  AI_CLONE
}

enum CheckInType {
  READING
  EMOTION
  FAMILY
}

enum HealingCategory {
  PARENT
  CHILD
  FAMILY
}
